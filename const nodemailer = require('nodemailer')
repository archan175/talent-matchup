const nodemailer = require('nodemailer');

const SKIP_EMAILS = process.env.SKIP_EMAILS === 'true';
const useDevTransport = SKIP_EMAILS || process.env.NODE_ENV !== 'production';

const transport = useDevTransport
  ? nodemailer.createTransport({ streamTransport: true, newline: 'unix', buffer: true })
  : nodemailer.createTransport({
      host: process.env.SMTP_HOST,
      port: process.env.SMTP_PORT || 587,
      secure: false,
      auth: { user: process.env.SMTP_USER, pass: process.env.SMTP_PASS }
    });

async function sendMailSafe(opts) {
  if (SKIP_EMAILS) {
    console.log('Skipping email (SKIP_EMAILS=true):', opts);
    return;
  }
  return transport.sendMail({
    from: process.env.EMAIL_FROM || 'no-reply@example.com',
    ...opts
  });
}

module.exports = { sendMailSafe };